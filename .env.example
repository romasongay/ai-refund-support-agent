# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in your real key.
# .env.local is git-ignored and must never be committed.
# ---------------------------------------------------------------------------

# OpenAI API key — used by the text agent and the voice pipeline (mini-tier models; the exact
# ids live in lib/config.ts). Create one at https://platform.openai.com/api-keys
# NOTE: do NOT prefix with NEXT_PUBLIC_ — that would leak the secret into the browser bundle.
OPENAI_API_KEY=sk-your-openai-key-here
